<%- include("partials/top") %>
<%
  const formatEuro = (value) => Number(value || 0).toFixed(2).replace(".", ",");
  const renderTally = (count) => {
    const safe = Math.min(count, 99);
    const fives = Math.floor(safe / 5);
    const rest = safe % 5;
    let html = '';
    for (let i = 0; i < fives; i++) {
      html += '<span class="tally-five">||||</span>';
      if ((i + 1) % 2 === 0 && (i + 1 < fives || rest > 0)) html += '<span class="tally-break"></span>';
    }
    if (rest > 0) html += '|'.repeat(rest);
    return html;
  };
  // Datum-Formatierung DD.MM.YYYY
  const formatDateDE = (isoStr) => {
    const [y, m, d] = isoStr.split("-");
    return `${d}.${m}.${y}`;
  };
%>

<nav class="gameday-nav" id="gamedayNav">
  <button type="button" id="btnPrev" title="Vorheriger Spieltag">◄</button>
  <div class="gameday-picker" id="gamedayPicker">
    <%
      const statusShort = ['', '', '⏳', '✓'];
      const allOptions = gamedays.map(day => ({
        value: String(day.id),
        label: formatDateDE(day.match_date) + (day.note ? ` - ${day.note}` : '') + (statusShort[day.settled] ? ` ${statusShort[day.settled]}` : ''),
        selected: selectedGameday && selectedGameday.id === day.id && !isNext
      }));
      const nextOpt = {
        value: 'next',
        label: `Nächster Spieltag (${formatDateDE(nextDate)})`,
        selected: isNext || (!selectedGameday && !hasGamedays)
      };
      allOptions.push(nextOpt);
      const currentLabel = (allOptions.find(o => o.selected) || allOptions[allOptions.length - 1]).label;
    %>
    <button type="button" class="gameday-picker-toggle" id="gamedayToggle"><%= currentLabel %></button>
    <div class="gameday-picker-dropdown" id="gamedayDropdown">
      <% allOptions.forEach((opt) => { %>
        <button type="button" class="gameday-picker-option<%= opt.selected ? ' is-active' : '' %>" data-value="<%= opt.value %>"><%= opt.label %></button>
      <% }) %>
    </div>
  </div>
  <button type="button" id="btnNext" title="Nächster Spieltag">►</button>
</nav>

<section class="card fade-in">
  <% if (isNext || (!selectedGameday && !hasGamedays)) { %>
    <!-- Nächster Spieltag: Vorschau + Starten -->
    <div class="start-gameday-bar">
      <form method="post" action="/kegelkladde/gamedays" class="start-gameday-form" id="startGamedayForm">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
        <label>Datum
          <input type="date" name="matchDate" value="<%= nextDate %>" required />
        </label>
        <label>Notiz (optional)
          <input name="note" maxlength="120" placeholder="z. B. Faschingsrunde" />
        </label>
        <button type="submit">Spieltag starten</button>
      </form>
    </div>

    <!-- Leere Kladde-Vorschau -->
    <div class="table-shell desktop-only">
      <table class="kladde-table kladde-preview">
        <colgroup>
          <col style="width: 110px;" />
          <col style="width: 44px;" />
          <col style="width: 70px;" /><!-- Übertrag -->
          <col style="width: 70px;" /><!-- Beitrag -->
          <col style="width: 52px;" />
          <col style="width: 64px;" />
          <col style="width: 64px;" />
          <col style="width: 64px;" />
          <col style="width: 64px;" />
          <col style="width: 52px;" />
          <col style="width: 52px;" />
          <col style="width: 52px;" />
          <col style="width: 52px;" />
          <col style="width: 52px;" /><!-- 25, 50 -->
          <col style="width: 70px;" />
        </colgroup>
        <thead>
          <tr>
            <th><span class="head-label">Name</span></th>
            <th><span class="head-label">Anwesend</span></th>
            <th><span class="head-label">Übertrag</span></th>
            <th><span class="head-label">Beitrag</span></th>
            <th><span class="head-label">Strafen</span></th>
            <th><span class="head-label">9er</span></th>
            <th><span class="head-label">Kranz</span></th>
            <th title="Triclops"><img src="/img/triclops_icon.png" alt="" class="triclops-th-icon" /><span class="head-label">Triclops</span></th>
            <th><span class="head-label">Pudel</span></th>
            <th class="game-col"><span class="head-label">V+A</span></th>
            <th class="game-col"><span class="head-label">Monte</span></th>
            <th class="game-col"><span class="head-label">Aussteigen</span></th>
            <th class="game-col"><span class="head-label">6-Tage</span></th>
            <th class="game-col"><span class="head-label">25, 50</span></th>
            <th class="topay-th"><span class="head-label">Zu zahlen</span></th>
          </tr>
        </thead>
        <tbody>
          <% regularMembers.forEach((member) => { %>
            <tr>
              <td class="name-col" data-name="<%= member.display_name %>"><%- renderAvatar(member, 'kladde-avatar') %><%= member.display_name %></td>
              <td>
                <label class="present-toggle">
                  <input type="checkbox" checked disabled />
                  <img src="/img/sheep.png" alt="Anwesend" class="present-icon" />
                </label>
              </td>
              <td><span class="money-text">0,00 &euro;</span></td>
              <td><span class="money-text"><%= formatEuro(4) %> &euro;</span></td>
              <td><span class="money-text">0,00 &euro;</span></td>
              <td><span class="money-text preview-dash">&mdash;</span></td>
              <td><span class="money-text preview-dash">&mdash;</span></td>
              <td><span class="money-text preview-dash">&mdash;</span></td>
              <td><span class="money-text preview-dash">&mdash;</span></td>
              <td class="game-col"><span class="money-text">0,00 &euro;</span></td>
              <td class="game-col"><span class="money-text">0,00 &euro;</span></td>
              <td class="game-col"><span class="money-text">0,00 &euro;</span></td>
              <td class="game-col"><span class="money-text">0,00 &euro;</span></td>
              <td class="game-col"><span class="money-text">0,00 &euro;</span></td>
              <td><span class="money-text">4,00 &euro;</span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="mobile-only">
      <p class="subtle" style="text-align: center; padding: 2rem 0;">
Spieltag starten, um die Kladde zu bearbeiten.
      </p>
    </div>

  <% } else if (selectedGameday) { %>

    <%
      const status = selectedGameday.settled;
      const statusLabels = ['Noch nicht begonnen', 'Spieltag läuft - gut Holz!', 'Abrechnung', 'Archiv'];
      const statusBadges = ['badge-muted', 'badge-warning', 'badge-info', 'badge-success'];
      const advanceLabels = [null, 'Abrechnen!', 'Abrechnung beenden'];
    %>

    <%
      let totalAlle9Present = 0, totalKranzPresent = 0, totalTriclopsPresent = 0;
      members.forEach((m) => {
        const h = attendanceMap.get(m.id) || { present: 0, alle9: 0, kranz: 0, triclops: 0 };
        if (h.present) {
          totalAlle9Present += Number(h.alle9 || 0);
          totalKranzPresent += Number(h.kranz || 0);
          totalTriclopsPresent += Number(h.triclops || 0);
        }
      });
    %>

    <div id="kladdeData" data-csrf="<%= csrfToken %>" data-gameday-id="<%= selectedGameday.id %>" data-status="<%= status %>" data-user-id="<%= currentUser.id %>" data-user-first-name="<%= currentUser.firstName %>" data-gags="<%= gagAnimations %>">
    <div class="table-shell">
        <table class="kladde-table">
          <colgroup>
            <col style="width: 110px;" /><!-- Name -->
            <col style="width: 44px;" /><!-- Anwesenheit -->
            <% if (status !== 1) { %>
            <col style="width: 62px;" /><!-- Übertrag -->
            <col style="width: 52px;" /><!-- Beitrag -->
            <col style="width: 52px;" /><!-- Strafen -->
            <% } %>
            <col style="width: <%= status >= 2 ? 40 : 60 %>px;" /><!-- 9er -->
            <col style="width: <%= status >= 2 ? 40 : 60 %>px;" /><!-- Kranz -->
            <col style="width: <%= status >= 2 ? 40 : 60 %>px;" /><!-- Triclops -->
            <col style="width: <%= status >= 2 ? 40 : 60 %>px;" /><!-- Pudel -->
            <col style="width: 44px;" /><!-- V+A -->
            <col style="width: 56px;" /><!-- Monte (+ Radio) -->
            <col style="width: 44px;" /><!-- Aussteigen -->
            <col style="width: 44px;" /><!-- 6-Tage -->
            <col style="width: 44px;" /><!-- 25, 50 -->
            <% customGames.forEach(() => { %>
            <col style="width: 44px;" />
            <% }) %>
            <% if (status <= 1) { %>
            <col style="width: 44px;" /><!-- Neue Spalte -->
            <% } %>
            <% if (status >= 2) { %>
            <col style="width: 62px;" /><!-- Spieltag gesamt -->
            <% } %>
            <col style="width: 62px;" /><!-- Zu zahlen -->
            <% if (status >= 2) { %>
            <col style="width: 62px;" /><!-- Gezahlt -->
            <col style="width: 62px;" /><!-- Rest -->
            <% } %>
          </colgroup>
          <thead>
            <tr>
              <th><span class="head-label">Name</span></th>
              <th><span class="head-label">Anwesend</span></th>
              <% if (status !== 1) { %>
              <th><span class="head-label">Übertrag</span></th>
              <th><span class="head-label">Beitrag</span></th>
              <th><span class="head-label">Strafen</span></th>
              <% } %>
              <th title="Alle 9"><span class="head-label">9er</span></th>
              <th title="Kranz"><span class="head-label">Kränze</span></th>
              <th title="Triclops"><img src="/img/triclops_icon.png" alt="" class="triclops-th-icon" /><span class="head-label">Triclops</span></th>
              <th><span class="head-label">Pudel</span></th>
              <th class="game-col"><% if (isAdmin && status === 1) { %><button type="button" class="live-game-btn" data-live-start="va" title="Live: V+A"><img src="/img/notlive.png" alt="Live" /></button><% } %><span class="head-label">V+A</span></th>
              <th class="game-col"><% if (isAdmin && status === 1) { %><button type="button" class="live-game-btn" data-live-start="monte" title="Live: Monte"><img src="/img/notlive.png" alt="Live" /></button><% } %><span class="head-label head-label-multiline">Monte<br/><br/><span class="head-sub"<br/>(+ Extrapunkt)</span></span></th>
              <th class="game-col"><% if (isAdmin && status === 1) { %><button type="button" class="live-game-btn" data-live-start="aussteigen" title="Live: Aussteigen"><img src="/img/notlive.png" alt="Live" /></button><% } %><span class="head-label">Aussteigen</span></th>
              <th class="game-col"><% if (isAdmin && status === 1) { %><button type="button" class="live-game-btn" data-live-start="sechs_tage" title="Live: 6-Tage-Rennen"><img src="/img/notlive.png" alt="Live" /></button><% } %><span class="head-label">6-Tage-Rennen</span></th>
              <th class="game-col">
                <% if (isAdmin && status === 1) { %>
                  <button type="button" class="live-game-btn" data-live-start="spiel_2550" title="Live: 25, 50"><img src="/img/notlive.png" alt="Live" /></button>
                <% } %>
                <span class="head-label">25, 50</span>
              </th>
              <% customGames.forEach((cg) => { %>
              <% if (status <= 1) { %>
              <th class="game-col custom-game-th" data-custom-game-th="<%= cg.id %>">
                <% if (isAdmin) { %><button type="button" class="live-game-btn" data-live-start="cg_<%= cg.id %>" title="Live: <%= cg.name %>"><img src="/img/notlive.png" alt="Live" /></button><% } %>
                <input type="text" class="custom-game-header-input" value="<%= cg.name %>"
                       data-custom-game-rename="<%= cg.id %>" data-original-name="<%= cg.name %>" />
                <button type="button" class="custom-game-delete-btn" data-custom-game-delete="<%= cg.id %>"
                        title="Spiel löschen">&times;</button>
              </th>
              <% } else { %>
              <th class="game-col"><span class="head-label"><%= cg.name %></span></th>
              <% } %>
              <% }) %>
              <% if (status <= 1) { %>
              <th class="game-col"><input type="text" class="custom-game-header-input" placeholder="Neues Spiel..." data-new-game-header /></th>
              <% } %>
              <% if (status >= 2) { %>
              <th><span class="head-label">Spieltag gesamt</span></th>
              <% } %>
              <th class="topay-th"><span class="head-label"><%= status === 1 ? 'Kosten Spieltag' : 'Zu zahlen' %></span></th>
              <% if (status >= 2) { %>
              <th><span class="head-label">Gezahlt</span></th>
              <th><span class="head-label">Rest</span></th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% members.forEach((member, i) => {
              const hit = attendanceMap.get(member.id) || { present: 0, penalties: 0, contribution: 0, pudel: 0, alle9: 0, kranz: 0, triclops: 0, carryover: 0, paid: 0 };
              const pudel = Number(hit.pudel || 0);
              const alle9 = Number(hit.alle9 || 0);
              const kranz = Number(hit.kranz || 0);
              const triclops = Number(hit.triclops || 0);
              let struck = {};
              try { struck = JSON.parse(hit.struck_games || '{}'); } catch { struck = {}; }
              const canEditMarks = status <= 1;
              const canEditPresent = canEditMarks;
              const isEditable = canEditMarks;
              const canEditPenalties = status <= 2;
              const canEdit = canEditMarks && hit.present;
              const canEditPaid = status === 2;
            %>
              <tr data-member-id="<%= member.id %>" class="<%= hit.present ? '' : 'row-inactive' %><%= member.is_guest ? ' row-guest' : '' %>">
                <%
                  const carryover = Number(hit.carryover || 0);
                %>
                <td class="name-col" data-name="<%= member.display_name %>">
                  <%- renderAvatar(member, 'kladde-avatar', attendanceMap.get(member.id)) %><%= member.display_name %>
                  <% if (member.is_guest) { %>
                    <span class="badge badge-muted badge-sm">Gast</span>
                    <% if (isAdmin && status <= 1) { %>
                      <form method="post" action="/kegelkladde/remove-guest" class="inline-form" data-confirm="Gast <%= member.display_name %> von diesem Spieltag entfernen?">
                        <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
                        <input type="hidden" name="gamedayId" value="<%= selectedGameday.id %>" />
                        <input type="hidden" name="guestId" value="<%= member.id %>" />
                        <button type="submit" class="guest-remove-btn" title="Gast entfernen">&times;</button>
                      </form>
                    <% } %>
                  <% } %>
                </td>
                <td class="present-col">
                  <label class="present-toggle" title="Anwesend">
                    <input type="checkbox" name="present_<%= member.id %>" <%= hit.present ? "checked" : "" %> <%= isEditable ? "" : "disabled" %> data-present />
                    <img src="/img/sheep.png" alt="Anwesend" class="present-icon" />
                  </label>
                </td>
                <% if (status !== 1) { %>
                <td data-label="Übertrag">
                  <span class="money-text" data-carryover data-value="<%= carryover %>"><%= formatEuro(carryover) %> &euro;</span>
                </td>
                <td data-label="Beitrag">
                  <span class="money-text"><%= formatEuro(hit.contribution || 0) %> €</span>
                </td>
                <td data-label="Strafen"><span class="money-inline"><input type="number" min="0" max="999" step="0.10" value="<%= (status <= 1 && !hit.present && Number(hit.penalties || 0) === 0) ? '' : Number(hit.penalties || 0).toFixed(2) %>" placeholder="<%= (status <= 1 && !hit.present && Number(hit.penalties || 0) === 0) ? 'TBD' : '' %>" name="penalties_<%= member.id %>" class="mini-number no-spin" <%= canEditPenalties ? "" : "disabled" %> data-field data-always-edit />&euro;</span></td>
                <% } %>
                <td class="marker-cell" data-label="9er">
                  <div class="marker-controls">
                    <input type="hidden" name="alle9_<%= member.id %>" value="<%= alle9 %>" data-marker-input="alle9" <%= canEdit ? "" : "disabled" %> data-field />
                    <button type="button" class="mark-btn mark-dec" data-mark-target="alle9" data-op="dec" aria-label="Alle 9 verringern" <%= canEdit ? "" : "disabled" %> data-field-btn>&minus;</button>
                    <span class="marker-strip" data-marker-display="alle9"><%- renderTally(alle9) %></span>
                    <button type="button" class="mark-btn" data-mark-target="alle9" data-op="inc" <%= canEdit ? "" : "disabled" %> data-field-btn>+</button>
                  </div>
                  <% const costAlle9 = hit.present ? (totalAlle9Present - alle9) * 0.10 : 0; %>
                  <span class="marker-cost" data-cost-type="alle9"><%= costAlle9 > 0 ? formatEuro(costAlle9) + ' €' : '' %></span>
                </td>
                <td class="marker-cell" data-label="Kränze">
                  <div class="marker-controls">
                    <input type="hidden" name="kranz_<%= member.id %>" value="<%= kranz %>" data-marker-input="kranz" <%= canEdit ? "" : "disabled" %> data-field />
                    <button type="button" class="mark-btn mark-dec" data-mark-target="kranz" data-op="dec" aria-label="Kranz verringern" <%= canEdit ? "" : "disabled" %> data-field-btn>&minus;</button>
                    <span class="marker-strip" data-marker-display="kranz"><%- renderTally(kranz) %></span>
                    <button type="button" class="mark-btn" data-mark-target="kranz" data-op="inc" <%= canEdit ? "" : "disabled" %> data-field-btn>+</button>
                  </div>
                  <% const costKranz = hit.present ? (totalKranzPresent - kranz) * 0.10 : 0; %>
                  <span class="marker-cost" data-cost-type="kranz"><%= costKranz > 0 ? formatEuro(costKranz) + ' €' : '' %></span>
                </td>
                <td class="marker-cell" data-label="Triclops">
                  <div class="marker-controls">
                    <input type="hidden" name="triclops_<%= member.id %>" value="<%= triclops %>" data-marker-input="triclops" <%= canEdit ? "" : "disabled" %> data-field />
                    <button type="button" class="mark-btn mark-dec" data-mark-target="triclops" data-op="dec" aria-label="Triclops verringern" <%= canEdit ? "" : "disabled" %> data-field-btn>&minus;</button>
                    <span class="marker-strip" data-marker-display="triclops"><%- renderTally(triclops) %></span>
                    <button type="button" class="mark-btn" data-mark-target="triclops" data-op="inc" <%= canEdit ? "" : "disabled" %> data-field-btn>+</button>
                  </div>
                  <% const costTriclops = hit.present ? (totalTriclopsPresent - triclops) * 0.10 : 0; %>
                  <span class="marker-cost" data-cost-type="triclops"><%= costTriclops > 0 ? formatEuro(costTriclops) + ' €' : '' %></span>
                </td>
                <td class="marker-cell" data-label="Pudel">
                  <div class="marker-controls">
                    <input type="hidden" name="pudel_<%= member.id %>" value="<%= pudel %>" data-marker-input="pudel" <%= canEdit ? "" : "disabled" %> data-field />
                    <button type="button" class="mark-btn mark-dec" data-mark-target="pudel" data-op="dec" aria-label="Pudel verringern" <%= canEdit ? "" : "disabled" %> data-field-btn>&minus;</button>
                    <span class="marker-strip" data-marker-display="pudel"><%- renderTally(pudel) %></span>
                    <button type="button" class="mark-btn" data-mark-target="pudel" data-op="inc" <%= canEdit ? "" : "disabled" %> data-field-btn>+</button>
                  </div>
                  <% const costPudel = hit.present ? pudel * 0.10 : 0; %>
                  <span class="marker-cost" data-cost-type="pudel"><%= costPudel > 0 ? formatEuro(costPudel) + ' €' : '' %></span>
                </td>
                <%
                  const vaVal = Number(hit.va || 0);
                  const monteVal = Number(hit.monte || 0);
                  const aussteigenVal = Number(hit.aussteigen || 0);
                  const sechsTageVal = Number(hit.sechs_tage || 0);
                %>
                <td class="game-col<%= struck.va ? ' cell-struck' : '' %>" data-label="V+A" data-game-key="va"><span class="money-inline"><input type="number" min="0" max="999" step="1" value="<%= Math.round(vaVal * 10) %>" name="va_<%= member.id %>" class="mini-number no-spin game-col-input" <%= canEdit ? "" : "disabled" %> data-field data-game-field /></span></td>
                <td class="game-col<%= struck.monte ? ' cell-struck' : '' %>" data-label="Monte" data-game-key="monte"><span class="money-inline"><input type="number" min="0" max="999" step="1" value="<%= Math.round(monteVal * 10) %>" name="monte_<%= member.id %>" class="mini-number no-spin game-col-input" <%= canEdit ? "" : "disabled" %> data-field data-game-field /><input type="radio" name="monte_extra" value="<%= member.id %>" class="monte-extra-radio" <%= hit.monte_extra ? 'checked' : '' %> <%= canEdit ? '' : 'disabled' %> data-monte-extra title="Extrapunkt" /></span><input type="hidden" name="monte_tiebreak_<%= member.id %>" value="<%= Number(hit.monte_tiebreak || 0) %>" data-tiebreak="monte" /></td>
                <td class="game-col<%= struck.aussteigen ? ' cell-struck' : '' %>" data-label="Aussteigen" data-game-key="aussteigen"><span class="money-inline"><input type="number" min="0" max="999" step="1" value="<%= Math.round(aussteigenVal * 10) %>" name="aussteigen_<%= member.id %>" class="mini-number no-spin game-col-input" <%= canEdit ? "" : "disabled" %> data-field data-game-field /></span><input type="hidden" name="aussteigen_tiebreak_<%= member.id %>" value="<%= Number(hit.aussteigen_tiebreak || 0) %>" data-tiebreak="aussteigen" /></td>
                <td class="game-col<%= struck.sechs_tage ? ' cell-struck' : '' %>" data-label="6-Tage" data-game-key="sechs_tage"><span class="money-inline"><input type="number" min="0" max="999" step="1" value="<%= Math.round(sechsTageVal * 10) %>" name="sechs_tage_<%= member.id %>" class="mini-number no-spin game-col-input" <%= canEdit ? "" : "disabled" %> data-field data-game-field /></span></td>
                <% const spiel2550Val = Number(hit.spiel_2550 || 0); %>
                <td class="game-col" data-label="25, 50" data-game-key="spiel_2550"><span class="money-inline"><input type="number" min="0" max="999" step="1" value="<%= Math.round(spiel2550Val * 10) %>" name="spiel_2550_<%= member.id %>" class="mini-number no-spin game-col-input" <%= canEdit ? "" : "disabled" %> data-field data-game-field /></span></td>
                <% customGames.forEach((cg) => {
                  const cgVal = Number(customGameValues.get(member.id + '_' + cg.id) || 0);
                  const cgKey = 'cg_' + cg.id;
                %>
                <td class="game-col<%= struck[cgKey] ? ' cell-struck' : '' %>" data-label="<%= cg.name %>" data-game-key="<%= cgKey %>"><span class="money-inline"><input type="number" min="0" max="999" step="1" value="<%= Math.round(cgVal * 10) %>" data-custom-game-id="<%= cg.id %>" class="mini-number no-spin game-col-input" <%= canEdit ? "" : "disabled" %> data-field data-custom-game-field /></span></td>
                <% }) %>
                <% if (status <= 1) { %>
                <td class="game-col newgame-placeholder"></td>
                <% } %>
                <%
                  const paid = Number(hit.paid || 0);
                  const pudelCostCalc = hit.present ? pudel * 0.10 : 0;
                  const alle9CostCalc = hit.present ? (totalAlle9Present - alle9) * 0.10 : 0;
                  const kranzCostCalc = hit.present ? (totalKranzPresent - kranz) * 0.10 : 0;
                  const triclopsCostCalc = hit.present ? (totalTriclopsPresent - triclops) * 0.10 : 0;
                  const gameCosts = hit.present ? vaVal + monteVal + aussteigenVal + sechsTageVal + spiel2550Val : 0;
                  let customGameTotal = 0;
                  if (hit.present) {
                    customGames.forEach((cg) => {
                      customGameTotal += Number(customGameValues.get(member.id + '_' + cg.id) || 0);
                    });
                  }
                  const toPay = status === 1
                    ? (hit.present ? pudelCostCalc + alle9CostCalc + kranzCostCalc + triclopsCostCalc + gameCosts + customGameTotal : 0)
                    : (hit.present ? (hit.contribution || 0) + (hit.penalties || 0) + pudelCostCalc + alle9CostCalc + kranzCostCalc + triclopsCostCalc + gameCosts + customGameTotal + carryover : (hit.contribution || 0) + (hit.penalties || 0) + carryover);
                  const rest = toPay - paid;
                %>
                <% if (status >= 2) {
                  const gameTotal = hit.present ? pudelCostCalc + alle9CostCalc + kranzCostCalc + triclopsCostCalc + gameCosts + customGameTotal : 0;
                %>
                <td data-label="Spieltag gesamt">
                  <span class="money-text" data-game-total><%= formatEuro(gameTotal) %> &euro;</span>
                </td>
                <% } %>
                <td class="topay-col" data-label="<%= status === 1 ? 'Kosten Spieltag' : 'Zu zahlen' %>">
                  <span class="money-text" data-topay><%= formatEuro(toPay) %> &euro;</span>
                </td>
                <% if (status >= 2) { %>
                <td data-label="Gezahlt">
                  <% if (canEditPaid) { %>
                    <span class="money-inline"><input type="number" min="0" max="9999" step="0.10" value="<%= paid.toFixed(2) %>" name="paid_<%= member.id %>" class="mini-number no-spin" data-paid-field data-always-edit />&euro;</span>
                  <% } else { %>
                    <span class="money-text" data-paid data-value="<%= paid %>"><%= formatEuro(paid) %> &euro;</span>
                  <% } %>
                </td>
                <td data-label="Rest">
                  <span class="money-text" data-rest><%= formatEuro(rest) %> &euro;</span>
                </td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
    </div>
    <div id="liveView" class="live-view" style="display:none;">
      <div class="live-sidebar">
        <div class="live-sidebar-header">
          <span class="live-sidebar-title" id="liveSidebarTitle">Live-Modus</span>
          <button type="button" class="live-close-btn" id="btnLiveClose" title="Zurück zur Tabelle">&times;</button>
        </div>
        <div id="liveShuffle" class="live-shuffle-area"></div>
        <div id="livePlayers" class="live-players"></div>
      </div>
      <div class="live-main">
        <div class="live-game-nav" id="liveGameNav" style="display:none">
          <button type="button" class="live-game-prev" id="btnLivePrev" title="Letztes Spiel" style="display:none">&#9664; Zurück</button>
          <span class="live-game-label" id="liveGameLabel"></span>
          <button type="button" class="live-game-next" id="btnLiveNext" title="Nächstes Spiel">Weiter &#9654;</button>
        </div>
        <div class="live-game-content" id="liveGameContent"></div>
      </div>
      <canvas id="liveFxCanvas" class="live-fx-canvas"></canvas>
    </div>
    </div>

    <% if (isAdmin && status <= 1) { %>
    <div class="guest-actions">
      <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('addGuestModal').classList.add('active')">+ Gast hinzufügen</button>
    </div>

    <!-- Gast hinzufügen Modal -->
    <div class="modal-overlay" id="addGuestModal">
      <div class="modal" style="max-width: 500px;">
        <h3>Gast hinzufügen</h3>

        <% if (availableGuests.length > 0) { %>
          <div style="margin-bottom: 1.5rem;">
            <h4 style="margin: 0 0 0.5rem;">Bekannten Gast wählen</h4>
            <form method="post" action="/kegelkladde/add-guest" class="form-grid">
              <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
              <input type="hidden" name="gamedayId" value="<%= selectedGameday.id %>" />
              <div class="form-row-2">
                <label>Gast
                  <select name="guestId" required>
                    <% availableGuests.forEach((g) => { %>
                      <option value="<%= g.id %>"><%= g.display_name %></option>
                    <% }) %>
                  </select>
                </label>
                <div style="display: flex; align-items: flex-end;">
                  <button type="submit" class="btn btn-sm">Hinzufügen</button>
                </div>
              </div>
            </form>
          </div>
          <hr style="border: none; border-top: 1px solid var(--line); margin: 1rem 0;" />
        <% } %>

        <h4 style="margin: 0 0 0.5rem;">Neuen Gast erstellen</h4>
        <form method="post" action="/kegelkladde/create-and-add-guest" class="form-grid">
          <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
          <input type="hidden" name="gamedayId" value="<%= selectedGameday.id %>" />
          <div class="form-row-2">
            <label>Vorname
              <input name="firstName" placeholder="Vorname" required maxlength="60" />
            </label>
            <label>Nachname (optional)
              <input name="lastName" placeholder="Nachname" maxlength="60" />
            </label>
          </div>
          <div class="member-actions">
            <button type="submit">Erstellen & hinzufügen</button>
            <button type="button" class="btn-secondary" onclick="document.getElementById('addGuestModal').classList.remove('active')">Abbrechen</button>
          </div>
        </form>
      </div>
    </div>
    <% } %>

    <!-- Footer: Status + Kassenstand-Aufstellung -->
    <div class="kladde-footer">
      <div class="settle-row">
        <p>
          Status:
          <span class="badge <%= statusBadges[status] %>"><%= statusLabels[status] %></span>
        </p>
        <div class="settle-actions">
          <% if (isAdmin) { %>
            <% if (status === 2) { %>
              <button type="button" class="btn-secondary btn-sm" id="btnPenaltyDetails" data-gameday-id="<%= selectedGameday.id %>">Strafen-Berechnung</button>
            <% } %>
            <% if (status > 0) { %>
              <form method="post" action="/kegelkladde/revert-status" data-confirm="Status wirklich zurücksetzen?">
                <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
                <input type="hidden" name="gamedayId" value="<%= selectedGameday.id %>" />
                <button type="submit" class="btn-secondary btn-sm">&laquo; Zurück</button>
              </form>
            <% } %>
            <% if (status >= 1 && status < 3) { %>
              <form method="post" action="/kegelkladde/advance-status" data-confirm="<%= advanceLabels[status] %>?">
                <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
                <input type="hidden" name="gamedayId" value="<%= selectedGameday.id %>" />
                <button type="submit" class="btn-primary btn-sm"><%= advanceLabels[status] %> &raquo;</button>
              </form>
            <% } %>
            <form method="post" action="/kegelkladde/delete" data-confirm="Spieltag wirklich löschen? Alle Daten gehen verloren!">
              <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
              <input type="hidden" name="gamedayId" value="<%= selectedGameday.id %>" />
              <button type="submit" class="btn-danger btn-sm">Löschen</button>
            </form>
            <button type="button" class="btn-new-gameday btn-sm" onclick="location.href='/kegelkladde?gamedayId=next'">+ Neuer Spieltag</button>
          <% } %>
        </div>
      </div>

      <div class="kassenstand-summary" id="kassenstandSummary"
           data-gameday-id="<%= selectedGameday.id %>"
           data-csrf="<%= csrfToken %>"
           data-status="<%= status %>">
        <table class="kassenstand-table">
          <tbody>
            <tr>
              <td>Alter Kassenstand:</td>
              <td class="ks-value" id="ksPrev"><%= formatEuro(ksGameday.previousKassenstand) %> &euro;</td>
            </tr>
            <tr>
              <td>+ Einnahmen:</td>
              <td class="ks-value ks-plus" id="ksPaid">+<%= formatEuro(ksGameday.gamedayPaid) %> &euro;</td>
            </tr>
            <% ksGameday.incomeItems.forEach((ci) => { %>
            <tr class="ks-entry-row" data-entry-id="<%= ci.id %>">
              <td>+ <%= ci.name %>:</td>
              <td class="ks-value ks-plus">
                <% if (status <= 2) { %>
                  <span class="money-inline">+<input type="number" min="0" max="9999" step="0.01" value="<%= Number(ci.amount).toFixed(2) %>" class="mini-number no-spin ks-entry-input" data-entry-id="<%= ci.id %>" />&euro;</span>
                <% } else { %>
                  +<%= formatEuro(ci.amount) %> &euro;
                <% } %>
              </td>
            </tr>
            <% }) %>
            <% if (status <= 2) { %>
            <tr class="ks-new-entry">
              <td colspan="2">
                <input type="text" class="ks-new-entry-input" placeholder="Neue Einnahme..." maxlength="40" data-entry-type="income" />
              </td>
            </tr>
            <% } %>
            <% ksGameday.costItems.forEach((ci) => { %>
            <tr class="ks-entry-row" data-entry-id="<%= ci.id %>">
              <td>&minus; <%= ci.name %>:</td>
              <td class="ks-value ks-minus">
                <% if (status <= 2) { %>
                  <span class="money-inline">&minus;<input type="number" min="0" max="9999" step="0.01" value="<%= Number(ci.amount).toFixed(2) %>" class="mini-number no-spin ks-entry-input" data-entry-id="<%= ci.id %>" />&euro;</span>
                <% } else { %>
                  &minus;<%= formatEuro(ci.amount) %> &euro;
                <% } %>
              </td>
            </tr>
            <% }) %>
            <% if (status <= 2) { %>
            <tr class="ks-new-entry">
              <td colspan="2">
                <input type="text" class="ks-new-entry-input" placeholder="Neue Kosten..." maxlength="40" data-entry-type="cost" />
              </td>
            </tr>
            <% } %>
            <tr class="ks-divider"><td colspan="2"></td></tr>
            <tr class="ks-total">
              <td>= Neuer Kassenstand:</td>
              <td class="ks-value" id="ksTotal"><%= formatEuro(ksGameday.kassenstand) %> &euro;</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <% if (isAdmin && status === 2) { %>
    <!-- Strafen-Modal -->
    <div class="modal-overlay" id="penaltyModal">
      <div class="modal" style="max-width: 600px;">
        <h3>Strafen-Berechnung</h3>
        <div id="penaltyModalContent"><p style="color: var(--muted);">Lade...</p></div>
        <div class="modal-actions" style="margin-top: 1rem;">
          <button type="button" class="btn-primary btn-sm" id="btnRecalcPenalties">Strafen neu berechnen</button>
          <button type="button" class="btn-secondary btn-sm" onclick="document.getElementById('penaltyModal').classList.remove('active')">Schließen</button>
        </div>
      </div>
    </div>
    <% } %>


  <% } %>
</section>

<script>
  // Close modal overlays on backdrop click
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) overlay.classList.remove('active');
    });
  });

  // Strafen-Modal Logik
  (function() {
    var btn = document.getElementById('btnPenaltyDetails');
    var modal = document.getElementById('penaltyModal');
    var content = document.getElementById('penaltyModalContent');
    var recalcBtn = document.getElementById('btnRecalcPenalties');
    if (!btn || !modal) return;

    var gamedayId = btn.dataset.gamedayId;

    function formatEuro(val) {
      return Number(val).toFixed(2).replace('.', ',');
    }

    function renderDetails(data) {
      var html = '';

      // Anwesende Spieler mit Kostenaufschlüsselung
      html += '<h4 style="margin: 0 0 0.5rem; font-size: 0.95rem;">Spielkosten der Anwesenden</h4>';
      html += '<table class="penalty-detail-table">';
      html += '<thead><tr><th>Spieler</th><th>9er</th><th>Kränze</th><th><img src="/img/triclops_icon.png" alt="Tricl." class="triclops-inline-icon" /></th><th>Pudel</th><th>Spiele</th><th>Gesamt</th></tr></thead>';
      html += '<tbody>';
      data.presentPlayers.forEach(function(p) {
        var isMin = p.total === data.minGameCost && data.minGameCost > 0;
        html += '<tr' + (isMin ? ' class="penalty-row-min"' : '') + '>';
        html += '<td>' + p.name + '</td>';
        html += '<td>' + formatEuro(p.alle9Cost) + '</td>';
        html += '<td>' + formatEuro(p.kranzCost) + '</td>';
        html += '<td>' + formatEuro(p.triclopsCost) + '</td>';
        html += '<td>' + formatEuro(p.pudelCost) + '</td>';
        html += '<td>' + formatEuro(p.gameCosts) + '</td>';
        html += '<td><strong>' + formatEuro(p.total) + ' &euro;</strong></td>';
        html += '</tr>';
      });
      html += '</tbody></table>';

      // Ergebnis
      if (data.minGameCost > 0 && data.cheapestPlayer) {
        html += '<p class="penalty-result">Günstigster Spieler: <strong>' + data.cheapestPlayer + '</strong> mit <strong>' + formatEuro(data.minGameCost) + ' &euro;</strong></p>';
      }

      // Abwesende Spieler
      if (data.absentPlayers.length > 0) {
        html += '<h4 style="margin: 1rem 0 0.5rem; font-size: 0.95rem;">Abwesende Spieler</h4>';
        html += '<table class="penalty-detail-table">';
        html += '<thead><tr><th>Spieler</th><th>Strafe</th><th>Quelle</th></tr></thead>';
        html += '<tbody>';
        data.absentPlayers.forEach(function(a) {
          html += '<tr>';
          html += '<td>' + a.name + '</td>';
          html += '<td><strong>' + formatEuro(a.currentPenalty) + ' &euro;</strong></td>';
          html += '<td>' + (a.isManual ? '<span class="badge badge-warning">Manuell</span>' : '<span class="badge badge-info">Auto</span>') + '</td>';
          html += '</tr>';
        });
        html += '</tbody></table>';
      } else {
        html += '<p style="color: var(--muted); margin-top: 0.75rem;">Keine abwesenden Spieler.</p>';
      }

      content.innerHTML = html;
    }

    function loadDetails() {
      content.innerHTML = '<p style="color: var(--muted);">Lade...</p>';
      fetch('/kegelkladde/penalty-details?gamedayId=' + gamedayId)
        .then(function(r) { return r.json(); })
        .then(renderDetails)
        .catch(function() { content.innerHTML = '<p style="color: var(--error);">Fehler beim Laden.</p>'; });
    }

    btn.addEventListener('click', function() {
      modal.classList.add('active');
      loadDetails();
    });

    recalcBtn.addEventListener('click', function() {
      recalcBtn.disabled = true;
      recalcBtn.textContent = 'Berechne...';
      var csrfToken = document.querySelector('[name="csrfToken"]')?.value || '';
      fetch('/kegelkladde/recalc-penalties', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
        body: JSON.stringify({ gamedayId: Number(gamedayId), csrfToken: csrfToken })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        renderDetails(data);
        recalcBtn.disabled = false;
        recalcBtn.textContent = 'Strafen neu berechnen';
        // Seite aktualisieren um neue Werte in der Tabelle zu zeigen
        setTimeout(function() { location.reload(); }, 800);
      })
      .catch(function() {
        content.innerHTML = '<p style="color: var(--error);">Fehler beim Neuberechnen.</p>';
        recalcBtn.disabled = false;
        recalcBtn.textContent = 'Strafen neu berechnen';
      });
    });
  })();
</script>
<%- include("partials/bottom") %>
