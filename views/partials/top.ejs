<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#2f8f6d" />
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <meta name="description" content="KC Schaf Zeilsheim - Vereinsportal für Kegelclub-Verwaltung" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><g fill='white' stroke='%23333' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><ellipse cx='32' cy='28' rx='22' ry='20'/><circle cx='32' cy='12' r='6'/><circle cx='22' cy='16' r='6'/><circle cx='42' cy='16' r='6'/><circle cx='18' cy='24' r='6'/><circle cx='46' cy='24' r='6'/><circle cx='20' cy='34' r='6'/><circle cx='44' cy='34' r='6'/><circle cx='26' cy='40' r='5'/><circle cx='38' cy='40' r='5'/><ellipse cx='32' cy='32' rx='12' ry='10'/><line x1='24' y1='44' x2='24' y2='56'/><line x1='40' y1='44' x2='40' y2='56'/></g><circle cx='28' cy='30' r='2' fill='%23333'/><circle cx='36' cy='30' r='2' fill='%23333'/><path d='M28 35q4 3 8 0' fill='none' stroke='%23333' stroke-width='2' stroke-linecap='round'/></svg>" />
  <title>KC Schaf Zeilsheim</title>
  <link rel="stylesheet" href="/style.css?v=<%= v %>" />
  <% if (sheepEnabled) { %><link rel="stylesheet" href="/flyingsheep.css?v=<%= v %>" />
  <% if (sheepConfig) { %><script>window.__sheepConfig=<%- typeof sheepConfig === 'string' ? sheepConfig : JSON.stringify(sheepConfig) %>;</script><% } %>
  <script defer src="/flyingsheep.js?v=<%= v %>"></script><% } %>
  <script defer src="/app.js?v=<%= v %>"></script>
</head>
<body<% if (typeof bodyClass !== 'undefined' && bodyClass) { %> class="<%= bodyClass %>"<% } %>>
  <% if (sheepEnabled) { %><div id="sheep-overlay"></div><% } %>
  <div class="background-glow"></div>

  <!-- Toast container for notifications -->
  <div id="toastContainer" class="toast-container"></div>

  <!-- Flash message data for JavaScript -->
  <% if (flash) { %>
    <script type="application/json" id="flashData"><%= JSON.stringify(flash) %></script>
  <% } %>

  <header class="topbar">
    <a href="/kegelkladde" class="brand">
      <img src="/img/sheep_title.png" alt="KC Schaf Maskottchen" class="brand-mascot" />
      <div>
        <strong>KC Schaf Zeilsheim</strong>
        <small>Per aspera ad astra - määh!</small>
      </div>
    </a>

    <% if (currentUser) { %>
      <!-- Desktop navigation -->
      <nav class="nav-links">
        <a href="/kegelkladde" class="<%= currentPath === '/kegelkladde' ? 'active' : '' %>">Kegelbuch</a>
        <a href="/kegelkladde" class="nav-live-btn" id="navLiveBtn" style="display:none;" title="Zum laufenden Spiel"><img src="/img/live-sign.png" alt="LIVE" class="nav-live-img" /></a>
        <a href="/ranglisten" class="<%= currentPath === '/ranglisten' ? 'active' : '' %>">Ranglisten</a>
        <a href="/statistik" class="<%= currentPath === '/statistik' ? 'active' : '' %>">Statistik</a>
        <a href="/rekorde" class="<%= currentPath === '/rekorde' ? 'active' : '' %>">Rekorde/Kurioses</a>
        <a href="/pinnwand" class="<%= currentPath === '/pinnwand' ? 'active' : '' %>">Pinnwand</a>
        <a href="/members" class="<%= currentPath === '/members' ? 'active' : '' %>">Mitglieder</a>
        <% if (isAdmin) { %><a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>">Einstellungen</a><% } %>
      </nav>

      <!-- Desktop profile + logout -->
      <div class="topbar-actions">
        <a href="/profil" class="profile-link" title="Mein Profil">
          <%- renderAvatar(currentUser, 'topbar-avatar') %>
        </a>
        <form method="post" action="/logout" class="logout-form">
          <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
          <button type="submit">Logout</button>
        </form>
      </div>

      <!-- Mobile menu toggle -->
      <button id="menuToggle" class="menu-toggle" aria-label="Menü öffnen">
        <span></span>
        <span></span>
        <span></span>
      </button>
    <% } %>
  </header>

  <% if (currentUser) { %>
    <!-- Mobile navigation -->
    <nav id="mobileNav" class="mobile-nav">
      <a href="/kegelkladde" class="<%= currentPath === '/kegelkladde' ? 'active' : '' %>">Kegelbuch</a>
      <a href="/kegelkladde" class="nav-live-btn" id="navLiveBtnMobile" style="display:none;" title="Zum laufenden Spiel"><img src="/img/live-sign.png" alt="LIVE" class="nav-live-img" /></a>
      <a href="/ranglisten" class="<%= currentPath === '/ranglisten' ? 'active' : '' %>">Ranglisten</a>
      <a href="/statistik" class="<%= currentPath === '/statistik' ? 'active' : '' %>">Statistik</a>
      <a href="/rekorde" class="<%= currentPath === '/rekorde' ? 'active' : '' %>">Rekorde/Kurioses</a>
      <a href="/pinnwand" class="<%= currentPath === '/pinnwand' ? 'active' : '' %>">Pinnwand</a>
      <a href="/members" class="<%= currentPath === '/members' ? 'active' : '' %>">Mitglieder</a>
      <% if (isAdmin) { %><a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>">Einstellungen</a><% } %>
      <a href="/profil" class="<%= currentPath === '/profil' ? 'active' : '' %>">
        <span class="mobile-nav-profile">
          <%- renderAvatar(currentUser, 'mobile-nav-avatar') %>
          Mein Profil
        </span>
      </a>
      <form method="post" action="/logout" style="margin-top: 0.5rem;">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
        <button type="submit" style="width: 100%;">Logout (<%= currentUser.firstName %>)</button>
      </form>
    </nav>
  <% } %>

  <main class="page-shell">
