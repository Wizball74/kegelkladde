<%- include("partials/top") %>
<%
  const formatEuro = (value) => Number(value || 0).toFixed(2).replace(".", ",");
  const formatDateDE = (d) => {
    if (!d) return '';
    const parts = d.split('-');
    return parts.length === 3 ? `${parts[2]}.${parts[1]}.${parts[0]}` : d;
  };
%>
<section class="card fade-in">
  <div class="section-head">
    <h1>Statistik</h1>
    <p class="subtle">Übersicht über alle Vereinsaktivitäten und Bestenlisten.</p>
  </div>

  <!-- Tabs -->
  <nav class="tab-nav">
    <button type="button" class="tab-btn active" data-tab="neuner-kraenze">Neuner / Kränze</button>
    <button type="button" class="tab-btn" data-tab="wurf-analyse">Wurf-Analyse</button>
    <button type="button" class="tab-btn" data-tab="allgemein">Allgemein</button>
    <button type="button" class="tab-btn" data-tab="ahnengalerie">Ahnengalerie</button>
  </nav>

  <!-- Tab 1: Neuner / Kränze -->
  <div class="tab-panel active" id="tab-neuner-kraenze">
    <div class="nk-grid">

    <!-- Neuner -->
    <div class="nk-section">
      <div class="nk-section-header">
        <span class="nk-section-icon">&#127923;</span>
        <h2>Neuner (Alle 9)</h2>
      </div>
      <% if (neunerStats.length > 0) { %>
        <div class="hbar-chart">
          <% neunerStats.forEach((item, i) => {
            const pct = maxNeuner > 0 ? Math.max((item.total / maxNeuner) * 100, 3) : 3;
            const rankClass = i === 0 ? 'hbar-rank-gold' : i === 1 ? 'hbar-rank-silver' : i === 2 ? 'hbar-rank-bronze' : '';
          %>
            <div class="hbar-row">
              <div class="hbar-label">
                <span class="hbar-rank <%= rankClass %>"><%= i + 1 %></span>
                <span class="hbar-name"><%= item.display_name || item.first_name %></span>
              </div>
              <div class="hbar-track">
                <div class="hbar-fill" style="width: <%= pct %>%;">
                  <div class="hbar-seg hbar-base" style="flex: 1;"></div>
                </div>
              </div>
              <span class="hbar-inline-value"><%= item.total %></span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">&#127923;</div>
          <p>Noch keine Neuner-Daten vorhanden.</p>
        </div>
      <% } %>
    </div>

    <!-- Kränze -->
    <div class="nk-section">
      <div class="nk-section-header">
        <span class="nk-section-icon">&#128081;</span>
        <h2>Kränze</h2>
      </div>
      <% if (kraenzeStats.length > 0) { %>
        <div class="hbar-chart">
          <% kraenzeStats.forEach((item, i) => {
            const pct = maxKraenze > 0 ? Math.max((item.total / maxKraenze) * 100, 3) : 3;
            const rankClass = i === 0 ? 'hbar-rank-gold' : i === 1 ? 'hbar-rank-silver' : i === 2 ? 'hbar-rank-bronze' : '';
          %>
            <div class="hbar-row">
              <div class="hbar-label">
                <span class="hbar-rank <%= rankClass %>"><%= i + 1 %></span>
                <span class="hbar-name"><%= item.display_name || item.first_name %></span>
              </div>
              <div class="hbar-track">
                <div class="hbar-fill" style="width: <%= pct %>%;">
                  <div class="hbar-seg hbar-gold" style="flex: 1;"></div>
                </div>
              </div>
              <span class="hbar-inline-value"><%= item.total %></span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">&#128081;</div>
          <p>Noch keine Kränze-Daten vorhanden.</p>
        </div>
      <% } %>
    </div>
    </div><!-- /nk-grid -->
  </div>

  <!-- Tab 2: Wurf-Analyse -->
  <div class="tab-panel" id="tab-wurf-analyse">
    <% if (!hasThrowLogData) { %>
      <div class="empty-state">
        <div class="empty-state-icon">&#128202;</div>
        <p>Noch keine Wurfdaten vorhanden.</p>
        <p class="subtle">Wurfdaten werden ab dem nächsten Spieltag automatisch erfasst.</p>
      </div>
    <% } else { %>

      <!-- Filter -->
      <div class="wa-filter-bar">
        <div class="wa-filter-row">
          <span class="wa-filter-label">Spiele:</span>
          <div class="wa-chips" id="waGameTypeChips"></div>
        </div>
        <div class="wa-filter-row">
          <span class="wa-filter-label">Zeitraum:</span>
          <input type="date" id="waDateFrom" class="wa-date-input" title="Von">
          <span class="wa-date-sep">&ndash;</span>
          <input type="date" id="waDateTo" class="wa-date-input" title="Bis">
          <button type="button" class="wa-reset-btn" id="waResetFilters" title="Filter zurücksetzen">&#10005;</button>
        </div>
      </div>

      <!-- Inhalte (werden per JS gefüllt) -->
      <div id="waContent">
        <div class="wa-loading">Lade Daten&hellip;</div>
      </div>

    <% } %>
  </div>

  <!-- Tab 3: Allgemein -->
  <div class="tab-panel" id="tab-allgemein">

    <!-- Dickstes Schaf -->
    <% if (dickstesSchaf) { %>
      <%
        const sheepScale = Math.min(1.6, 1 + dickstesSchaf.combined / 800);
      %>
      <div class="dickstes-schaf-card" style="--sheep-scale: <%= sheepScale.toFixed(2) %>;">
        <div class="dickstes-schaf-title">Dickstes Schaf</div>
        <div class="dickstes-schaf-img">
          <img src="/img/sheep.png" alt="Schaf">
        </div>
        <div class="dickstes-schaf-name"><%= dickstesSchaf.display_name || dickstesSchaf.first_name %></div>
        <div class="dickstes-schaf-counts">
          <strong><%= dickstesSchaf.total_neuner %></strong> Neuner +
          <strong><%= dickstesSchaf.total_kraenze %></strong> Kränze =
          <strong><%= dickstesSchaf.combined %></strong> gesamt
        </div>
      </div>
    <% } %>

    <!-- Summary stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= totalGamedays %></div>
        <div class="stat-label">Spieltage</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= settledGamedays %></div>
        <div class="stat-label">Abgerechnet</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= formatEuro(totalPaid) %> €</div>
        <div class="stat-label">Zahlungen</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= totalPenalties %></div>
        <div class="stat-label">Strafen</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= memberCount %></div>
        <div class="stat-label">Mitglieder</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= guestCount %></div>
        <div class="stat-label">Gäste</div>
      </div>
    </div>

    <!-- Leaderboards -->
    <div class="split-grid">
      <% if (topAttendance.length > 0) { %>
        <div class="leaderboard">
          <div class="leaderboard-header">Meiste Teilnahmen</div>
          <% topAttendance.forEach((item, i) => { %>
            <div class="leaderboard-item">
              <span class="leaderboard-rank"><%= i + 1 %></span>
              <span class="leaderboard-name"><%= item.display_name || item.first_name %></span>
              <span class="leaderboard-value"><%= item.games %> Spiele</span>
            </div>
          <% }) %>
        </div>
      <% } %>

      <% if (topPayers.length > 0) { %>
        <div class="leaderboard">
          <div class="leaderboard-header">Summe Zahlungen</div>
          <% topPayers.forEach((item, i) => { %>
            <div class="leaderboard-item">
              <span class="leaderboard-rank"><%= i + 1 %></span>
              <span class="leaderboard-name"><%= item.display_name || item.first_name %></span>
              <span class="leaderboard-value"><%= formatEuro(item.total) %> €</span>
            </div>
          <% }) %>
        </div>
      <% } %>

      <% if (mostPudel.length > 0) { %>
        <div class="leaderboard">
          <div class="leaderboard-header">Meiste Pudel</div>
          <% mostPudel.forEach((item, i) => { %>
            <div class="leaderboard-item">
              <span class="leaderboard-rank"><%= i + 1 %></span>
              <span class="leaderboard-name"><%= item.display_name || item.first_name %></span>
              <span class="leaderboard-value"><%= item.total %>×</span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <% if (monthlySummary.length > 0) { %>
      <h2 style="margin-top: 2rem;">Monatsübersicht <%= currentYear %></h2>
      <div class="records-table-wrap">
        <table class="records-table">
          <thead>
            <tr>
              <th>Monat</th>
              <th>Spieltage</th>
              <th>Beiträge</th>
              <th>Strafen</th>
            </tr>
          </thead>
          <tbody>
            <% monthlySummary.forEach((month) => { %>
              <tr>
                <td><%= month.monthName %></td>
                <td><%= month.gamedays %></td>
                <td><%= formatEuro(month.contributions) %> €</td>
                <td><%= month.penalties %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (recentGamedays.length > 0) { %>
      <h2 style="margin-top: 2rem;">Letzte Spieltage</h2>
      <div class="records-table-wrap">
        <table class="records-table">
          <thead>
            <tr>
              <th>Datum</th>
              <th>Notiz</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% recentGamedays.forEach((day) => { %>
              <tr>
                <td><a href="/kegelkladde?gamedayId=<%= day.id %>"><%= day.match_date %></a></td>
                <td><%= day.note || '-' %></td>
                <%
                  const sLabels = ['Noch nicht begonnen', 'Spieltag läuft - gut Holz!', 'Abrechnung', 'Archiv'];
                  const sBadges = ['badge-muted', 'badge-warning', 'badge-info', 'badge-success'];
                %>
                <td>
                  <span class="badge <%= sBadges[day.settled] || 'badge-muted' %>"><%= sLabels[day.settled] || 'Unbekannt' %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Tab 4: Ahnengalerie -->
  <div class="tab-panel" id="tab-ahnengalerie">
    <% if (!stalls || stalls.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">&#129702;</div>
        <p>Die Ahnengalerie ist noch leer.</p>
        <p class="subtle">Hier erscheinen alle Schafe, die das Zeitliche gesegnet haben.</p>
      </div>
    <% } else { %>
      <div class="stall-grid">
        <% stalls.forEach((stall) => { %>
          <div class="stall">
            <div class="stall-header">
              <span class="stall-name"><%= stall.name %></span>
              <span class="stall-count"><%= stall.stats.total %> Schaf<%= stall.stats.total !== 1 ? 'e' : '' %></span>
            </div>
            <div class="stall-ground">
              <% stall.sheep.forEach((sheep, idx) => {
                const traits = JSON.parse(sheep.traits_json);
                const canDelete = isAdmin || (currentUser && String(sheep.owner_id) === String(currentUser.id));
              %>
                <div class="stall-sheep"
                  data-traits="<%= encodeURIComponent(JSON.stringify(traits)) %>"
                  data-size="<%= sheep.size_multiplier %>"
                  data-letter="<%= sheep.letter %>"
                  data-sheep-id="<%= sheep.id %>"
                  data-age-ms="<%= sheep.age_ms %>"
                  data-died-at="<%= sheep.died_at %>"
                  data-death-cause="<%= sheep.death_cause %>">
                  <% if (canDelete) { %>
                    <button type="button" class="stall-sheep-delete" data-delete-sheep="<%= sheep.id %>" title="Schaf löschen">&times;</button>
                  <% } %>
                </div>
              <% }) %>
            </div>
            <div class="stall-stats">
              <% if (stall.stats.evicted > 0) { %><span>&#128116; <%= stall.stats.evicted %></span><% } %>
              <% if (stall.stats.thrown > 0) { %><span>&#128640; <%= stall.stats.thrown %></span><% } %>
              <% if (stall.stats.dismissed > 0) { %><span>&#128075; <%= stall.stats.dismissed %></span><% } %>
              <% if (stall.stats.departed > 0) { %><span>&#9992;&#65039; <%= stall.stats.departed %></span><% } %>
              <% if (stall.stats.stuck > 0) { %><span>&#128027; <%= stall.stats.stuck %></span><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
<% if (hasThrowLogData) { %>
<script>
(function() {
  var waContent = document.getElementById("waContent");
  var chipsEl = document.getElementById("waGameTypeChips");
  var dateFromEl = document.getElementById("waDateFrom");
  var dateToEl = document.getElementById("waDateTo");
  var resetBtn = document.getElementById("waResetFilters");
  if (!waContent || !chipsEl) return;

  var ALL_TYPES = [
    { key: "va", label: "V+A" },
    { key: "monte", label: "Monte" },
    { key: "aussteigen", label: "Aussteigen" },
    { key: "sechs_tage", label: "6-Tage" },
    { key: "spiel_2550", label: "25 / 50" }
  ];
  var activeTypes = {};
  ALL_TYPES.forEach(function(t) { activeTypes[t.key] = true; });

  // Chips rendern
  function renderChips(available) {
    chipsEl.innerHTML = "";
    ALL_TYPES.forEach(function(t) {
      var has = available.indexOf(t.key) !== -1;
      var chip = document.createElement("button");
      chip.type = "button";
      chip.className = "wa-chip" + (activeTypes[t.key] ? " active" : "") + (!has ? " wa-chip-empty" : "");
      chip.dataset.type = t.key;
      chip.textContent = t.label;
      if (!has) { chip.disabled = true; chip.title = "Keine Daten"; }
      chip.addEventListener("click", function() {
        activeTypes[t.key] = !activeTypes[t.key];
        chip.classList.toggle("active", activeTypes[t.key]);
        fetchData();
      });
      chipsEl.appendChild(chip);
    });
  }

  // Initiale Chips (alle aktiv)
  renderChips(ALL_TYPES.map(function(t) { return t.key; }));

  function esc(s) { var d = document.createElement("div"); d.textContent = s; return d.innerHTML; }

  function formatDateDE(d) {
    if (!d) return "";
    var p = d.split("-");
    return p.length === 3 ? p[2] + "." + p[1] + "." + p[0] : d;
  }

  function rankClass(i) {
    return i === 0 ? "hbar-rank-gold" : i === 1 ? "hbar-rank-silver" : i === 2 ? "hbar-rank-bronze" : "";
  }

  function renderResults(data) {
    if (!data.totalPinsPerPlayer.length && !data.pinDistribution.length && !data.throwAvgByGameday.length) {
      waContent.innerHTML = '<div class="empty-state"><div class="empty-state-icon">&#128202;</div><p>Keine Daten f\u00fcr diese Filterauswahl.</p></div>';
      return;
    }
    var html = "";

    // Gesamt gefallene Pins
    if (data.totalPinsPerPlayer.length > 0) {
      var maxPins = data.totalPinsPerPlayer[0].total_pins;
      html += '<div class="nk-section"><div class="nk-section-header"><span class="nk-section-icon">&#127935;</span><h2>Gesamt gefallene Pins</h2></div>';
      html += '<div class="hbar-chart">';
      data.totalPinsPerPlayer.forEach(function(item, i) {
        var pct = maxPins > 0 ? Math.max((item.total_pins / maxPins) * 100, 3) : 3;
        var name = esc(item.display_name || item.first_name);
        html += '<div class="hbar-row"><div class="hbar-label"><span class="hbar-rank ' + rankClass(i) + '">' + (i+1) + '</span><span class="hbar-name">' + name + '</span></div>';
        html += '<div class="hbar-track"><div class="hbar-fill" style="width:' + pct + '%"><div class="hbar-seg hbar-teal" style="flex:1"></div></div></div>';
        html += '<span class="hbar-inline-value">' + item.total_pins + ' <small>(' + item.avg_throw.toFixed(2) + ' \u00d8)</small></span></div>';
      });
      html += '</div></div>';
    }

    // Pin-Verteilung
    if (data.pinDistribution.length > 0) {
      html += '<div class="nk-section"><div class="nk-section-header"><span class="nk-section-icon">&#128200;</span><h2>Pin-Verteilung</h2></div>';
      html += '<div class="pin-dist-grid">';
      data.pinDistribution.forEach(function(player) {
        var maxCount = Math.max.apply(null, player.distribution.concat([1]));
        var name = esc(player.display_name || player.first_name);
        html += '<div class="pin-dist-card"><div class="pin-dist-header"><span class="pin-dist-name">' + name + '</span><span class="pin-dist-total">' + player.totalThrows + ' W\u00fcrfe</span></div>';
        html += '<div class="pin-dist-bars">';
        for (var v = 0; v <= 9; v++) {
          var count = player.distribution[v];
          var hPct = (count / maxCount) * 100;
          html += '<div class="pin-dist-col"><span class="pin-dist-count">' + (count > 0 ? count : "") + '</span><div class="pin-dist-bar pin-dist-v' + v + '" style="height:' + hPct + '%"></div><span class="pin-dist-label">' + v + '</span></div>';
        }
        html += '</div></div>';
      });
      html += '</div></div>';
    }

    // Wurf-Schnitt pro Spieltag
    if (data.throwAvgByGameday.length > 0) {
      html += '<div class="nk-section"><div class="nk-section-header"><span class="nk-section-icon">&#128197;</span><h2>Wurf-Schnitt pro Spieltag</h2></div>';
      data.throwAvgByGameday.forEach(function(gd) {
        html += '<div class="throw-avg-gameday"><div class="throw-avg-date">' + esc(formatDateDE(gd.match_date)) + '</div>';
        html += '<div class="hbar-chart hbar-chart-compact">';
        gd.players.forEach(function(p, i) {
          var pct = Math.max((p.avg_throw / 9) * 100, 3);
          var name = esc(p.display_name || p.first_name);
          html += '<div class="hbar-row"><div class="hbar-label"><span class="hbar-rank ' + rankClass(i) + '">' + (i+1) + '</span><span class="hbar-name">' + name + '</span></div>';
          html += '<div class="hbar-track"><div class="hbar-fill" style="width:' + pct + '%"><div class="hbar-seg hbar-base" style="flex:1"></div></div></div>';
          html += '<span class="hbar-inline-value">' + p.avg_throw.toFixed(2) + '</span></div>';
        });
        html += '</div></div>';
      });
      html += '</div>';
    }

    waContent.innerHTML = html;
  }

  var fetchTimer = null;
  function fetchData() {
    clearTimeout(fetchTimer);
    fetchTimer = setTimeout(doFetch, 150);
  }

  function doFetch() {
    var types = [];
    for (var k in activeTypes) { if (activeTypes[k]) types.push(k); }
    var params = new URLSearchParams();
    if (types.length < ALL_TYPES.length) params.set("gameTypes", types.join(","));
    if (dateFromEl.value) params.set("dateFrom", dateFromEl.value);
    if (dateToEl.value) params.set("dateTo", dateToEl.value);

    var url = "/statistik/wurf-analyse" + (params.toString() ? "?" + params.toString() : "");
    waContent.innerHTML = '<div class="wa-loading">Lade Daten\u2026</div>';

    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        // Update chips: markiere welche Spieltypen verfügbar sind
        var available = (data.availableGameTypes || []).map(function(t) { return t.key; });
        renderChips(available);
        // Datum-Grenzen setzen
        if (data.gamedayDates && data.gamedayDates.length > 0) {
          var minDate = data.gamedayDates[0].match_date;
          var maxDate = data.gamedayDates[data.gamedayDates.length - 1].match_date;
          dateFromEl.min = minDate;
          dateFromEl.max = maxDate;
          dateToEl.min = minDate;
          dateToEl.max = maxDate;
        }
        renderResults(data);
      })
      .catch(function() {
        waContent.innerHTML = '<div class="empty-state"><p>Fehler beim Laden der Daten.</p></div>';
      });
  }

  dateFromEl.addEventListener("change", fetchData);
  dateToEl.addEventListener("change", fetchData);
  resetBtn.addEventListener("click", function() {
    ALL_TYPES.forEach(function(t) { activeTypes[t.key] = true; });
    dateFromEl.value = "";
    dateToEl.value = "";
    fetchData();
  });

  // Tab-Klick: beim ersten Öffnen laden
  var loaded = false;
  var tabBtn = document.querySelector('.tab-btn[data-tab="wurf-analyse"]');
  if (tabBtn) {
    tabBtn.addEventListener("click", function() {
      if (!loaded) { loaded = true; fetchData(); }
    });
  }
  // Falls Tab schon aktiv (z.B. über URL-Hash)
  var panel = document.getElementById("tab-wurf-analyse");
  if (panel && panel.classList.contains("active") && !loaded) { loaded = true; fetchData(); }
})();
</script>
<% } %>
<%- include("partials/bottom") %>
