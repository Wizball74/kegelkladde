<%- include("partials/top") %>
<%
  const formatEuro = (value) => Number(value || 0).toFixed(2).replace(".", ",");
  const formatDateDE = (d) => {
    if (!d) return '';
    const parts = d.split('-');
    return parts.length === 3 ? `${parts[2]}.${parts[1]}.${parts[0]}` : d;
  };
%>
<section class="card fade-in">
  <div class="section-head">
    <h1>Statistik</h1>
    <p class="subtle">Übersicht über alle Vereinsaktivitäten und Bestenlisten.</p>
  </div>

  <!-- Tabs -->
  <nav class="tab-nav">
    <button type="button" class="tab-btn active" data-tab="neuner-kraenze">Neuner / Kränze</button>
    <button type="button" class="tab-btn" data-tab="wurf-analyse">Wurf-Analyse</button>
    <button type="button" class="tab-btn" data-tab="allgemein">Allgemein</button>
    <button type="button" class="tab-btn" data-tab="ahnengalerie">Ahnengalerie</button>
  </nav>

  <!-- Tab 1: Neuner / Kränze -->
  <div class="tab-panel active" id="tab-neuner-kraenze">
    <div class="nk-grid">

    <!-- Neuner -->
    <div class="nk-section">
      <div class="nk-section-header">
        <span class="nk-section-icon">&#127923;</span>
        <h2>Neuner (Alle 9)</h2>
      </div>
      <% if (neunerStats.length > 0) { %>
        <div class="hbar-chart">
          <% neunerStats.forEach((item, i) => {
            const pct = maxNeuner > 0 ? Math.max((item.total / maxNeuner) * 100, 3) : 3;
            const rankClass = i === 0 ? 'hbar-rank-gold' : i === 1 ? 'hbar-rank-silver' : i === 2 ? 'hbar-rank-bronze' : '';
          %>
            <div class="hbar-row">
              <div class="hbar-label">
                <span class="hbar-rank <%= rankClass %>"><%= i + 1 %></span>
                <span class="hbar-name"><%= item.display_name || item.first_name %></span>
              </div>
              <div class="hbar-track">
                <div class="hbar-fill" style="width: <%= pct %>%;">
                  <div class="hbar-seg hbar-base" style="flex: 1;"></div>
                </div>
              </div>
              <span class="hbar-inline-value"><%= item.total %></span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">&#127923;</div>
          <p>Noch keine Neuner-Daten vorhanden.</p>
        </div>
      <% } %>
    </div>

    <!-- Kränze -->
    <div class="nk-section">
      <div class="nk-section-header">
        <span class="nk-section-icon">&#128081;</span>
        <h2>Kränze</h2>
      </div>
      <% if (kraenzeStats.length > 0) { %>
        <div class="hbar-chart">
          <% kraenzeStats.forEach((item, i) => {
            const pct = maxKraenze > 0 ? Math.max((item.total / maxKraenze) * 100, 3) : 3;
            const rankClass = i === 0 ? 'hbar-rank-gold' : i === 1 ? 'hbar-rank-silver' : i === 2 ? 'hbar-rank-bronze' : '';
          %>
            <div class="hbar-row">
              <div class="hbar-label">
                <span class="hbar-rank <%= rankClass %>"><%= i + 1 %></span>
                <span class="hbar-name"><%= item.display_name || item.first_name %></span>
              </div>
              <div class="hbar-track">
                <div class="hbar-fill" style="width: <%= pct %>%;">
                  <div class="hbar-seg hbar-gold" style="flex: 1;"></div>
                </div>
              </div>
              <span class="hbar-inline-value"><%= item.total %></span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">&#128081;</div>
          <p>Noch keine Kränze-Daten vorhanden.</p>
        </div>
      <% } %>
    </div>
    </div><!-- /nk-grid -->
  </div>

  <!-- Tab 2: Wurf-Analyse -->
  <div class="tab-panel" id="tab-wurf-analyse">
    <% if (!hasThrowLogData) { %>
      <div class="empty-state">
        <div class="empty-state-icon">&#128202;</div>
        <p>Noch keine Wurfdaten vorhanden.</p>
        <p class="subtle">Wurfdaten werden ab dem nächsten Spieltag automatisch erfasst.</p>
      </div>
    <% } else { %>

      <!-- Gesamt gefallene Pins -->
      <div class="nk-section">
        <div class="nk-section-header">
          <span class="nk-section-icon">&#127935;</span>
          <h2>Gesamt gefallene Pins</h2>
        </div>
        <% if (totalPinsPerPlayer.length > 0) { %>
          <%
            const maxPins = totalPinsPerPlayer[0].total_pins;
          %>
          <div class="hbar-chart">
            <% totalPinsPerPlayer.forEach((item, i) => {
              const pct = maxPins > 0 ? Math.max((item.total_pins / maxPins) * 100, 3) : 3;
              const rankClass = i === 0 ? 'hbar-rank-gold' : i === 1 ? 'hbar-rank-silver' : i === 2 ? 'hbar-rank-bronze' : '';
            %>
              <div class="hbar-row">
                <div class="hbar-label">
                  <span class="hbar-rank <%= rankClass %>"><%= i + 1 %></span>
                  <span class="hbar-name"><%= item.display_name || item.first_name %></span>
                </div>
                <div class="hbar-track">
                  <div class="hbar-fill" style="width: <%= pct %>%;">
                    <div class="hbar-seg hbar-teal" style="flex: 1;"></div>
                  </div>
                </div>
                <span class="hbar-inline-value"><%= item.total_pins %></span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Pin-Verteilung -->
      <div class="nk-section">
        <div class="nk-section-header">
          <span class="nk-section-icon">&#128200;</span>
          <h2>Pin-Verteilung</h2>
        </div>
        <% if (pinDistribution.length > 0) { %>
          <div class="pin-dist-grid">
            <% pinDistribution.forEach((player) => {
              const maxCount = Math.max(...player.distribution, 1);
            %>
              <div class="pin-dist-card">
                <div class="pin-dist-header">
                  <span class="pin-dist-name"><%= player.display_name || player.first_name %></span>
                  <span class="pin-dist-total"><%= player.totalThrows %> Würfe</span>
                </div>
                <div class="pin-dist-bars">
                  <% for (let v = 0; v <= 9; v++) {
                    const count = player.distribution[v];
                    const heightPct = (count / maxCount) * 100;
                  %>
                    <div class="pin-dist-col">
                      <span class="pin-dist-count"><%= count > 0 ? count : '' %></span>
                      <div class="pin-dist-bar pin-dist-v<%= v %>" style="height: <%= heightPct %>%;"></div>
                      <span class="pin-dist-label"><%= v %></span>
                    </div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Wurf-Schnitt pro Spieltag -->
      <div class="nk-section">
        <div class="nk-section-header">
          <span class="nk-section-icon">&#128197;</span>
          <h2>Wurf-Schnitt pro Spieltag</h2>
        </div>
        <% throwAvgByGameday.forEach((gd) => { %>
          <div class="throw-avg-gameday">
            <div class="throw-avg-date"><%= formatDateDE(gd.match_date) %></div>
            <div class="hbar-chart hbar-chart-compact">
              <% gd.players.forEach((p, i) => {
                const pct = Math.max((p.avg_throw / 9) * 100, 3);
                const rankClass = i === 0 ? 'hbar-rank-gold' : i === 1 ? 'hbar-rank-silver' : i === 2 ? 'hbar-rank-bronze' : '';
              %>
                <div class="hbar-row">
                  <div class="hbar-label">
                    <span class="hbar-rank <%= rankClass %>"><%= i + 1 %></span>
                    <span class="hbar-name"><%= p.display_name || p.first_name %></span>
                  </div>
                  <div class="hbar-track">
                    <div class="hbar-fill" style="width: <%= pct %>%;">
                      <div class="hbar-seg hbar-base" style="flex: 1;"></div>
                    </div>
                  </div>
                  <span class="hbar-inline-value"><%= p.avg_throw.toFixed(2) %></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>

    <% } %>
  </div>

  <!-- Tab 3: Allgemein -->
  <div class="tab-panel" id="tab-allgemein">

    <!-- Dickstes Schaf -->
    <% if (dickstesSchaf) { %>
      <%
        const sheepScale = Math.min(1.6, 1 + dickstesSchaf.combined / 800);
      %>
      <div class="dickstes-schaf-card" style="--sheep-scale: <%= sheepScale.toFixed(2) %>;">
        <div class="dickstes-schaf-title">Dickstes Schaf</div>
        <div class="dickstes-schaf-img">
          <img src="/img/sheep.png" alt="Schaf">
        </div>
        <div class="dickstes-schaf-name"><%= dickstesSchaf.display_name || dickstesSchaf.first_name %></div>
        <div class="dickstes-schaf-counts">
          <strong><%= dickstesSchaf.total_neuner %></strong> Neuner +
          <strong><%= dickstesSchaf.total_kraenze %></strong> Kränze =
          <strong><%= dickstesSchaf.combined %></strong> gesamt
        </div>
      </div>
    <% } %>

    <!-- Summary stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= totalGamedays %></div>
        <div class="stat-label">Spieltage</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= settledGamedays %></div>
        <div class="stat-label">Abgerechnet</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= formatEuro(totalPaid) %> €</div>
        <div class="stat-label">Zahlungen</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= totalPenalties %></div>
        <div class="stat-label">Strafen</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= memberCount %></div>
        <div class="stat-label">Mitglieder</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= guestCount %></div>
        <div class="stat-label">Gäste</div>
      </div>
    </div>

    <!-- Leaderboards -->
    <div class="split-grid">
      <% if (topAttendance.length > 0) { %>
        <div class="leaderboard">
          <div class="leaderboard-header">Meiste Teilnahmen</div>
          <% topAttendance.forEach((item, i) => { %>
            <div class="leaderboard-item">
              <span class="leaderboard-rank"><%= i + 1 %></span>
              <span class="leaderboard-name"><%= item.display_name || item.first_name %></span>
              <span class="leaderboard-value"><%= item.games %> Spiele</span>
            </div>
          <% }) %>
        </div>
      <% } %>

      <% if (topPayers.length > 0) { %>
        <div class="leaderboard">
          <div class="leaderboard-header">Summe Zahlungen</div>
          <% topPayers.forEach((item, i) => { %>
            <div class="leaderboard-item">
              <span class="leaderboard-rank"><%= i + 1 %></span>
              <span class="leaderboard-name"><%= item.display_name || item.first_name %></span>
              <span class="leaderboard-value"><%= formatEuro(item.total) %> €</span>
            </div>
          <% }) %>
        </div>
      <% } %>

      <% if (mostPudel.length > 0) { %>
        <div class="leaderboard">
          <div class="leaderboard-header">Meiste Pudel</div>
          <% mostPudel.forEach((item, i) => { %>
            <div class="leaderboard-item">
              <span class="leaderboard-rank"><%= i + 1 %></span>
              <span class="leaderboard-name"><%= item.display_name || item.first_name %></span>
              <span class="leaderboard-value"><%= item.total %>×</span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <% if (monthlySummary.length > 0) { %>
      <h2 style="margin-top: 2rem;">Monatsübersicht <%= currentYear %></h2>
      <div class="records-table-wrap">
        <table class="records-table">
          <thead>
            <tr>
              <th>Monat</th>
              <th>Spieltage</th>
              <th>Beiträge</th>
              <th>Strafen</th>
            </tr>
          </thead>
          <tbody>
            <% monthlySummary.forEach((month) => { %>
              <tr>
                <td><%= month.monthName %></td>
                <td><%= month.gamedays %></td>
                <td><%= formatEuro(month.contributions) %> €</td>
                <td><%= month.penalties %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (recentGamedays.length > 0) { %>
      <h2 style="margin-top: 2rem;">Letzte Spieltage</h2>
      <div class="records-table-wrap">
        <table class="records-table">
          <thead>
            <tr>
              <th>Datum</th>
              <th>Notiz</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% recentGamedays.forEach((day) => { %>
              <tr>
                <td><a href="/kegelkladde?gamedayId=<%= day.id %>"><%= day.match_date %></a></td>
                <td><%= day.note || '-' %></td>
                <%
                  const sLabels = ['Noch nicht begonnen', 'Spieltag läuft - gut Holz!', 'Abrechnung', 'Archiv'];
                  const sBadges = ['badge-muted', 'badge-warning', 'badge-info', 'badge-success'];
                %>
                <td>
                  <span class="badge <%= sBadges[day.settled] || 'badge-muted' %>"><%= sLabels[day.settled] || 'Unbekannt' %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Tab 4: Ahnengalerie -->
  <div class="tab-panel" id="tab-ahnengalerie">
    <% if (!stalls || stalls.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">&#129702;</div>
        <p>Die Ahnengalerie ist noch leer.</p>
        <p class="subtle">Hier erscheinen alle Schafe, die das Zeitliche gesegnet haben.</p>
      </div>
    <% } else { %>
      <div class="stall-grid">
        <% stalls.forEach((stall) => { %>
          <div class="stall">
            <div class="stall-header">
              <span class="stall-name"><%= stall.name %></span>
              <span class="stall-count"><%= stall.stats.total %> Schaf<%= stall.stats.total !== 1 ? 'e' : '' %></span>
            </div>
            <div class="stall-ground">
              <% stall.sheep.forEach((sheep, idx) => {
                const traits = JSON.parse(sheep.traits_json);
                const canDelete = isAdmin || (currentUser && String(sheep.owner_id) === String(currentUser.id));
              %>
                <div class="stall-sheep"
                  data-traits="<%= encodeURIComponent(JSON.stringify(traits)) %>"
                  data-size="<%= sheep.size_multiplier %>"
                  data-letter="<%= sheep.letter %>"
                  data-sheep-id="<%= sheep.id %>">
                  <% if (canDelete) { %>
                    <button type="button" class="stall-sheep-delete" data-delete-sheep="<%= sheep.id %>" title="Schaf löschen">&times;</button>
                  <% } %>
                </div>
              <% }) %>
            </div>
            <div class="stall-stats">
              <% if (stall.stats.evicted > 0) { %><span>&#128116; <%= stall.stats.evicted %></span><% } %>
              <% if (stall.stats.thrown > 0) { %><span>&#128640; <%= stall.stats.thrown %></span><% } %>
              <% if (stall.stats.dismissed > 0) { %><span>&#128075; <%= stall.stats.dismissed %></span><% } %>
              <% if (stall.stats.departed > 0) { %><span>&#9992;&#65039; <%= stall.stats.departed %></span><% } %>
              <% if (stall.stats.stuck > 0) { %><span>&#128027; <%= stall.stats.stuck %></span><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
<%- include("partials/bottom") %>
