<%- include("partials/top") %>

<section class="card fade-in umkleide-page">
  <div class="section-head" style="display:flex;align-items:center;flex-wrap:wrap;gap:.75rem;">
    <div style="flex:1;">
      <h1 style="margin:0;">Schaf-Umkleide</h1>
      <p class="subtle" style="margin:.25rem 0 0;">Accessoire-Positionen und -Gr&ouml;&szlig;en testen und dauerhaft anpassen.</p>
    </div>
    <a href="/admin" class="btn-sm">&larr; Einstellungen</a>
  </div>

  <div class="umkleide-layout">
    <!-- Vorschau -->
    <div class="umkleide-preview-panel">
      <div class="umkleide-preview" id="umkleidePreview"></div>

      <details class="umkleide-body-details" open>
        <summary>K&ouml;rper (nur Vorschau)</summary>
        <div class="umkleide-body-controls">
          <label>Gr&ouml;&szlig;e <input type="range" id="pScale" min="0.4" max="1.6" step="0.05" value="1.0"><span id="pScaleV">1.0</span></label>
          <label>Rundung <input type="range" id="pChub" min="0.5" max="1.5" step="0.05" value="1.0"><span id="pChubV">1.0</span></label>
          <label>Kopf <input type="range" id="pHead" min="0.6" max="1.4" step="0.05" value="1.0"><span id="pHeadV">1.0</span></label>
          <label>Beine <input type="range" id="pLegs" min="0.7" max="1.8" step="0.05" value="1.2"><span id="pLegsV">1.2</span></label>
          <label>Schwanz <input type="range" id="pTail" min="2" max="7" step="0.5" value="4"><span id="pTailV">4</span></label>
          <label>Schwarz <input type="checkbox" id="pBlack"></label>
          <label>Propeller <input type="checkbox" id="pPropeller" checked></label>
          <label>Propeller-Gr&ouml;&szlig;e <input type="range" id="pPropSize" min="0.6" max="1.5" step="0.05" value="1.0"><span id="pPropSizeV">1.0</span></label>
          <label>Fl&uuml;gel-Farbe <input type="color" id="pPropColor" value="#ffd740"></label>
          <label>Naben-Farbe <input type="color" id="pPropHubColor" value="#666666"></label>
          <label>Fl&uuml;gel-Anzahl
            <select id="pPropBladeCount">
              <option value="2" selected>2</option>
              <option value="3">3</option>
              <option value="4">4</option>
            </select>
          </label>
          <label>Fl&uuml;gel-Form
            <select id="pPropShape">
              <option value="standard" selected>Standard</option>
              <option value="round">Rund</option>
              <option value="slim">Schmal</option>
              <option value="teardrop">Tropfen</option>
            </select>
          </label>
          <label>Farbe <input type="color" id="pAccColor" value="#e44444"></label>
          <div style="margin-top:.5rem;">
            <button type="button" class="btn-sm" id="btnRandomBody">Zuf&auml;lliges Schaf</button>
          </div>
        </div>
      </details>
    </div>

    <!-- Accessoire-Controls -->
    <div class="umkleide-controls-panel">
      <div class="tab-nav">
        <button type="button" class="tab-btn active" data-tab="u-huete">Kopf</button>
        <button type="button" class="tab-btn" data-tab="u-brillen">Brillen</button>
        <button type="button" class="tab-btn" data-tab="u-baerte">B&auml;rte</button>
        <button type="button" class="tab-btn" data-tab="u-koerper">K&ouml;rper</button>
        <button type="button" class="tab-btn" data-tab="u-schwanz">Schwanz</button>
        <button type="button" class="tab-btn" data-tab="u-gesicht">Gesicht</button>
      </div>

      <!-- Sprite-H&uuml;te -->
      <div id="tab-u-huete" class="tab-panel active">
        <div class="umkleide-sprite-grid" id="hatGrid"></div>
        <div class="umkleide-sliders" id="hatItemSliders" style="display:none;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">Kopf <span id="hatItemLabel">#0</span> (Feinkorrektur)</h3>
          <label>dY <input type="range" id="hatIdY" min="-8" max="8" step="0.5" value="0"><span id="hatIdYV">0</span>px</label>
          <label>dX <input type="range" id="hatIdX" min="-8" max="8" step="0.5" value="0"><span id="hatIdXV">0</span>px</label>
          <label>dGr&ouml;&szlig;e <input type="range" id="hatIdS" min="0.5" max="2.0" step="0.05" value="1"><span id="hatIdSV">1</span>x</label>
        </div>
        <div class="umkleide-sliders umkleide-global-locked" style="margin-top:.5rem;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">
            <button type="button" class="umkleide-lock-btn" title="Entsperren um globale Werte zu &auml;ndern">&#128274;</button>
            Alle Kopf-Sprites (global)
          </h3>
          <div class="umkleide-global-sliders">
            <label>Position Y <input type="range" id="hatY" min="-20" max="5" step="0.5" value="-8"><span id="hatYV">-8</span>px</label>
            <label>Position X <input type="range" id="hatX" min="-10" max="10" step="0.5" value="0"><span id="hatXV">0</span>px</label>
            <label>Gr&ouml;&szlig;e <input type="range" id="hatS" min="0.5" max="2.5" step="0.05" value="1.0"><span id="hatSV">1.0</span>x</label>
          </div>
        </div>
      </div>

      <!-- Sprite-Brillen -->
      <div id="tab-u-brillen" class="tab-panel">
        <div class="umkleide-sprite-grid" id="glassesGrid"></div>
        <div class="umkleide-sliders" id="glItemSliders" style="display:none;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">Brille <span id="glItemLabel">#0</span> (Feinkorrektur)</h3>
          <label>dY <input type="range" id="glIdY" min="-8" max="8" step="0.5" value="0"><span id="glIdYV">0</span>px</label>
          <label>dX <input type="range" id="glIdX" min="-8" max="8" step="0.5" value="0"><span id="glIdXV">0</span>px</label>
          <label>dGr&ouml;&szlig;e <input type="range" id="glIdS" min="0.5" max="2.0" step="0.05" value="1"><span id="glIdSV">1</span>x</label>
        </div>
        <div class="umkleide-sliders umkleide-global-locked" style="margin-top:.5rem;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">
            <button type="button" class="umkleide-lock-btn" title="Entsperren um globale Werte zu &auml;ndern">&#128274;</button>
            Alle Brillen (global)
          </h3>
          <div class="umkleide-global-sliders">
            <label>Position Y <input type="range" id="glY" min="-10" max="10" step="0.5" value="1.5"><span id="glYV">1.5</span>px</label>
            <label>Position X <input type="range" id="glX" min="-10" max="10" step="0.5" value="0"><span id="glXV">0</span>px</label>
            <label>Gr&ouml;&szlig;e <input type="range" id="glS" min="0.5" max="2.5" step="0.05" value="1.0"><span id="glSV">1.0</span>x</label>
          </div>
        </div>
      </div>

      <!-- Sprite-B&auml;rte -->
      <div id="tab-u-baerte" class="tab-panel">
        <div class="umkleide-sprite-grid" id="stacheGrid"></div>
        <div class="umkleide-sliders" id="stItemSliders" style="display:none;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">Bart <span id="stItemLabel">#0</span> (Feinkorrektur)</h3>
          <label>dY <input type="range" id="stIdY" min="-8" max="8" step="0.5" value="0"><span id="stIdYV">0</span>px</label>
          <label>dX <input type="range" id="stIdX" min="-8" max="8" step="0.5" value="0"><span id="stIdXV">0</span>px</label>
          <label>dGr&ouml;&szlig;e <input type="range" id="stIdS" min="0.5" max="2.0" step="0.05" value="1"><span id="stIdSV">1</span>x</label>
        </div>
        <div class="umkleide-sliders umkleide-global-locked" style="margin-top:.5rem;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">
            <button type="button" class="umkleide-lock-btn" title="Entsperren um globale Werte zu &auml;ndern">&#128274;</button>
            Alle B&auml;rte (global)
          </h3>
          <div class="umkleide-global-sliders">
            <label>Position Y <input type="range" id="stY" min="-8" max="8" step="0.5" value="-1"><span id="stYV">-1</span>px</label>
            <label>Position X <input type="range" id="stX" min="-10" max="10" step="0.5" value="0"><span id="stXV">0</span>px</label>
            <label>Gr&ouml;&szlig;e <input type="range" id="stS" min="0.5" max="2.5" step="0.05" value="1.0"><span id="stSV">1.0</span>x</label>
          </div>
        </div>
      </div>

      <!-- Sprite-K&ouml;rper -->
      <div id="tab-u-koerper" class="tab-panel">
        <p class="subtle" style="margin:0 0 .5rem;font-size:.78rem;">Standard: Buchstabe auf dem Torso. Custom-Sprites werden dar&uuml;ber gelegt.</p>
        <div class="umkleide-sprite-grid" id="bodyGrid"></div>
        <div class="umkleide-sliders" id="bodyItemSliders" style="display:none;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">K&ouml;rper-Sprite <span id="bodyItemLabel">#0</span> (Feinkorrektur)</h3>
          <label>dY <input type="range" id="bodyIdY" min="-8" max="8" step="0.5" value="0"><span id="bodyIdYV">0</span>px</label>
          <label>dX <input type="range" id="bodyIdX" min="-8" max="8" step="0.5" value="0"><span id="bodyIdXV">0</span>px</label>
          <label>dGr&ouml;&szlig;e <input type="range" id="bodyIdS" min="0.5" max="2.0" step="0.05" value="1"><span id="bodyIdSV">1</span>x</label>
        </div>
        <div class="umkleide-sliders umkleide-global-locked" style="margin-top:.5rem;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">
            <button type="button" class="umkleide-lock-btn" title="Entsperren um globale Werte zu &auml;ndern">&#128274;</button>
            Alle K&ouml;rper-Sprites (global)
          </h3>
          <div class="umkleide-global-sliders">
            <label>Position Y <input type="range" id="bodyY" min="-10" max="10" step="0.5" value="0"><span id="bodyYV">0</span>px</label>
            <label>Position X <input type="range" id="bodyX" min="-10" max="10" step="0.5" value="0"><span id="bodyXV">0</span>px</label>
            <label>Gr&ouml;&szlig;e <input type="range" id="bodyS" min="0.5" max="2.5" step="0.05" value="1.0"><span id="bodySV">1.0</span>x</label>
          </div>
        </div>
      </div>

      <!-- Sprite-Schwanz -->
      <div id="tab-u-schwanz" class="tab-panel">
        <p class="subtle" style="margin:0 0 .5rem;font-size:.78rem;">Standard: Wollkn&auml;uel. Custom-Sprites werden dar&uuml;ber gelegt.</p>
        <div class="umkleide-sprite-grid" id="tailGrid"></div>
        <div class="umkleide-sliders" id="tailItemSliders" style="display:none;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">Schwanz-Sprite <span id="tailItemLabel">#0</span> (Feinkorrektur)</h3>
          <label>dY <input type="range" id="tailIdY" min="-8" max="8" step="0.5" value="0"><span id="tailIdYV">0</span>px</label>
          <label>dX <input type="range" id="tailIdX" min="-8" max="8" step="0.5" value="0"><span id="tailIdXV">0</span>px</label>
          <label>dGr&ouml;&szlig;e <input type="range" id="tailIdS" min="0.5" max="2.0" step="0.05" value="1"><span id="tailIdSV">1</span>x</label>
        </div>
        <div class="umkleide-sliders umkleide-global-locked" style="margin-top:.5rem;">
          <h3 style="margin:0 0 .4rem;font-size:.85rem;">
            <button type="button" class="umkleide-lock-btn" title="Entsperren um globale Werte zu &auml;ndern">&#128274;</button>
            Alle Schwanz-Sprites (global)
          </h3>
          <div class="umkleide-global-sliders">
            <label>Position Y <input type="range" id="tailY" min="-10" max="10" step="0.5" value="0"><span id="tailYV">0</span>px</label>
            <label>Position X <input type="range" id="tailX" min="-10" max="10" step="0.5" value="0"><span id="tailXV">0</span>px</label>
            <label>Gr&ouml;&szlig;e <input type="range" id="tailS" min="0.5" max="2.5" step="0.05" value="1.0"><span id="tailSV">1.0</span>x</label>
          </div>
        </div>
      </div>

      <!-- Gesicht -->
      <div id="tab-u-gesicht" class="tab-panel">
        <div class="umkleide-sliders">
          <h3 style="margin:0 0 .5rem;font-size:.9rem;">Augen</h3>
          <label>H&ouml;he <input type="range" id="fEyeY" min="0" max="8" step="0.5" value="3.5"><span id="fEyeYV">3.5</span>px</label>
          <label>Links X <input type="range" id="fEyeLX" min="0" max="5" step="0.25" value="2"><span id="fEyeLXV">2</span>px</label>
          <label>Rechts X <input type="range" id="fEyeRX" min="0" max="5" step="0.25" value="2"><span id="fEyeRXV">2</span>px</label>
        </div>
        <div class="umkleide-sliders" style="margin-top:.75rem;">
          <h3 style="margin:0 0 .5rem;font-size:.9rem;">Ohren</h3>
          <label>H&ouml;he <input type="range" id="fEarY" min="-5" max="3" step="0.5" value="-1.5"><span id="fEarYV">-1.5</span>px</label>
          <label>Links X <input type="range" id="fEarLX" min="-5" max="0" step="0.25" value="-2.5"><span id="fEarLXV">-2.5</span>px</label>
          <label>Rechts X <input type="range" id="fEarRX" min="-5" max="0" step="0.25" value="-2.5"><span id="fEarRXV">-2.5</span>px</label>
        </div>
        <div class="umkleide-sliders" style="margin-top:.75rem;">
          <h3 style="margin:0 0 .5rem;font-size:.9rem;">Mund</h3>
          <label>H&ouml;he <input type="range" id="fMouthY" min="0" max="5" step="0.25" value="2"><span id="fMouthYV">2</span>px</label>
        </div>
      </div>
    </div>
  </div>

  <div class="umkleide-actions">
    <button type="button" class="btn-primary" id="btnSave">Konfiguration speichern</button>
    <button type="button" id="btnReset">Auf Standard zur&uuml;cksetzen</button>
    <span style="flex:1;"></span>
    <button type="button" class="btn-sm" id="btnExport" title="Config als JSON exportieren">Exportieren</button>
    <button type="button" class="btn-sm" id="btnImport" title="Config-JSON importieren">Importieren</button>
    <input type="file" id="importFile" accept=".json" hidden />
    <input type="file" id="slotSpriteFile" accept="image/png,image/webp,image/jpeg" hidden />
  </div>
</section>

<script>window.__umkleideConfig = <%- JSON.stringify(sheepConfig) %>;</script>
<link rel="stylesheet" href="/flyingsheep.css?v=<%= v %>" />
<script src="/umkleide.js?v=<%= v %>"></script>
<%- include("partials/bottom") %>
